# ROS 2 environment variables
# ROS_DOMAIN_ID isolates this container's ROS traffic from other machines on LAN
ROS_DOMAIN_ID=42

# Use the default FastDDS middleware
RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# Gazebo Classic settings
GAZEBO_MASTER_URI=http://localhost:11345

# ── Software rendering (no GPU) ───────────────────────────────────────────────
# Use LLVM-JIT Mesa backend — significantly faster than default softpipe
GALLIUM_DRIVER=llvmpipe
LIBGL_ALWAYS_SOFTWARE=1
# Disable vsync; software rendering doesn't benefit from it
__GL_SYNC_TO_VBLANK=0
# Ogre (Gazebo's renderer): FBO is faster than pbuffer/copy for offscreen render
OGRE_RTT_MODE=FBO
